# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, never expose to the client. Used by lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# n8n webhook URL (local Docker n8n via ngrok tunnel while testing, e.g. https://xxxx.ngrok-free.app/webhook/user-created)
N8N_WEBHOOK_URL=

# Shared secret used to HMAC-sign the webhook payload sent to n8n; must match the secret n8n uses to verify it.
WEBHOOK_SIGNING_SECRET=
